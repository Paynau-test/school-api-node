{
  "name": "school-api-serverless",
  "version": "1.0.0",
  "description": "Serverless API for student CRUD operations (Node.js + Lambda + API Gateway)",
  "type": "module",
  "scripts": {
    "dev": "sam local start-api --warm-containers eager",
    "build": "sam build",
    "deploy": "sam deploy --no-confirm-changeset",
    "invoke:create": "sam local invoke CreateStudentFunction --event events/create-student.json",
    "invoke:get": "sam local invoke GetStudentFunction --event events/get-student.json",
    "invoke:search": "sam local invoke SearchStudentsFunction --event events/search-students.json"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.11.0"
  }
}
